<wpf:ResourceDictionary xml:space="preserve"
                        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
                        xmlns:s="clr-namespace:System;assembly=mscorlib"
                        xmlns:ss="urn:shemas-jetbrains-com:settings-storage-reflection"
                        xmlns:wpf="http://schemas.microsoft.com/winfx/2000/xaml/presentation">

  <s:String x:Key="/Default/CodeInspection/Highlighting/DotCoverAttributeFilters/=ExcludeFromCodeCoverage/@EntryIndexedValue">ExcludeFromCodeCoverage</s:String>
  <s:String x:Key="/Default/DotCover/CoverageAnalysis/Filters/Id/@EntryValue">CustomFilters</s:String>

  <s:String x:Key="/Default/DotCover/CoverageAnalysis/Filters/ExcludedFilters/=Filter0/@EntryIndexedValue">
    &lt;Filter&gt;
    &lt;ClassMask&gt;L2.Application.DTOs.*&lt;/ClassMask&gt;
    &lt;/Filter&gt;
  </s:String>
  <s:String x:Key="/Default/DotCover/CoverageAnalysis/Filters/ExcludedFilters/=Filter1/@EntryIndexedValue">&lt;Filter&gt;&lt;ClassMask&gt;L2.Application.Models.*&lt;/ClassMask&gt;&lt;/Filter&gt;</s:String>
  <s:String x:Key="/Default/DotCover/CoverageAnalysis/Filters/IncludedFilters/=Filter2/@EntryIndexedValue">&lt;Filter&gt;&lt;ClassMask&gt;L2.Application.Models.Meta*&lt;/ClassMask&gt;&lt;/Filter&gt;</s:String>

</wpf:ResourceDictionary>
